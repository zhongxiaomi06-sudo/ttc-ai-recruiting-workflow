# TTC Daemon server deployment
TTC_DAEMON_HOST=0.0.0.0
TTC_DAEMON_PORT=8766
TTC_DATA_DIR=/data
TTC_SCHEDULER_INTERVAL=10

# Set this in server deployments. Browser scripts and webhook clients send it as X-TTC-Token.
TTC_API_TOKEN=change-me-to-a-long-random-secret

# Existing company talent database
TTC_TALENT_DB_ENABLED=false
TTC_TALENT_DB_URL=
TTC_TALENT_DB_KEY=
TTC_TALENT_DB_QUERY_PATH=/api/candidates/search

# Source company talent database: use API or a JSON file mounted into /data
TTC_SOURCE_TALENT_ENABLED=false
TTC_SOURCE_TALENT_FILE=/data/source-candidates.json
TTC_SOURCE_TALENT_URL=
TTC_SOURCE_TALENT_KEY=
TTC_SOURCE_TALENT_QUERY_PATH=/api/candidates/search
# Or connect Source talent directly from MySQL/RDS.
# Leave these empty to reuse TTC_MYSQL_* when set.
TTC_SOURCE_TALENT_MYSQL_HOST=
TTC_SOURCE_TALENT_MYSQL_PORT=3306
TTC_SOURCE_TALENT_MYSQL_DATABASE=
TTC_SOURCE_TALENT_MYSQL_USER=
TTC_SOURCE_TALENT_MYSQL_PASSWORD=

# Mature web/file readers
TTC_WEB_READER=auto
TTC_FIRECRAWL_API_KEY=
TTC_FIRECRAWL_BASE_URL=https://api.firecrawl.dev
TTC_CRAWL4AI_ENABLED=false
TTC_FILE_READER=markitdown

# Feishu Bot notifications (optional)
TTC_FEISHU_BOT_WEBHOOK=
TTC_DASHBOARD_URL=http://127.0.0.1:8766

# LLM parsing/scoring
TTC_LLM_PROVIDER=openai
TTC_LLM_API_KEY=
TTC_LLM_BASE_URL=
TTC_LLM_MODEL=gpt-4o-mini

# Candidate collector can stay local at first; set this to a reachable server URL when deployed.
TTC_CC_URL=http://host.docker.internal:8765
