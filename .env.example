# 复制为 .env 后填充真实值

# Daemon 认证（保护 /ingest/* 写接口）
TTC_API_TOKEN=change-me

# 飞书 CLI 通知
TTC_FEISHU_NOTIFY_ENABLED=false
TTC_FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TTC_DASHBOARD_URL=http://127.0.0.1:8766

# 阿里云 AccessKey
ALIBABA_CLOUD_ACCESS_KEY_ID=your-ak-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-ak-secret
ALIBABA_CLOUD_REGION=cn-hangzhou

# LLM（可选）
TTC_LLM_PROVIDER=openai
TTC_LLM_API_KEY=your-llm-api-key
TTC_LLM_BASE_URL=https://api.openai.com/v1
TTC_LLM_MODEL=gpt-4o-mini

# Source 人才库 JSON 文件（可选）
TTC_SOURCE_TALENT_ENABLED=false
TTC_SOURCE_TALENT_FILE=/path/to/source-candidates.json
