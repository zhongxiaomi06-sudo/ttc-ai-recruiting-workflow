# 复制为 .env 后填充真实值

# Daemon 认证（保护 /ingest/* 写接口）
TTC_API_TOKEN=change-me

# 飞书 CLI 通知
TTC_FEISHU_NOTIFY_ENABLED=false
TTC_FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TTC_DASHBOARD_URL=http://127.0.0.1:8766

# 飞书人才库自动搜索（工作流 sourcing 阶段自动召回）
TTC_FEISHU_BASE_ENABLED=false
TTC_FEISHU_BASE_TOKEN=your-feishu-base-token
TTC_FEISHU_BASE_TABLE_ID=tblWFuBQrPmllE9W
TTC_FEISHU_BASE_VIEW_ID=vewhTzpFAm
TTC_FEISHU_BASE_MAPPING_PATH=
TTC_FEISHU_BASE_MAX_QUERIES=10
TTC_FEISHU_BASE_SEARCH_LIMIT=20
TTC_FEISHU_BASE_RATE_LIMIT_QPS=2
TTC_FEISHU_BASE_KEYWORD_MAX_LEN=50

# 阿里云 AccessKey
ALIBABA_CLOUD_ACCESS_KEY_ID=your-ak-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-ak-secret
ALIBABA_CLOUD_REGION=cn-hangzhou

# 云端 RDS MySQL（candidate-collector 云同步 + AI 长期记忆，zhongxiaomi MCP 用）
# 注意：连接走 pymysql（MySQL），不是 PostgreSQL；没有 RDS_SSLMODE 这个配置项
RDS_HOST=your-rds-host.mysql.rds.aliyuncs.com
RDS_PORT=3306
RDS_DB=ttc_talent
RDS_USER=your-db-user
RDS_PASSWORD=your-db-password
RDS_SYNC_BATCH_SIZE=100
# RDS_SYNC_DRY_RUN=true  # 设为 true 只预览，不写入

# LLM（可选）
TTC_LLM_PROVIDER=openai
TTC_LLM_API_KEY=your-llm-api-key
# Kimi Code 用户请用：https://api.kimi.com/coding/v1，模型：kimi-for-coding
# Moonshot Open Platform 用户请用：https://api.moonshot.cn/v1 或 https://api.moonshot.ai/v1
TTC_LLM_BASE_URL=https://api.kimi.com/coding/v1
TTC_LLM_MODEL=kimi-for-coding
# 马赛克手机号视觉恢复（Kimi Code / OpenAI 兼容 vision 模型）
ENABLE_MOSAIC_PHONE_RECOVERY=false
TTC_LLM_VISION_MODEL=kimi-for-coding
# 精准画像匹配 Agent（OpenAI 兼容的 DeepSeek API）
DEEPSEEK_API_KEY=your-deepseek-api-key
TTC_JWT_TOKEN=your-ttc-jwt-token
TTC_SCORING_PROVIDER=heuristic
TTC_TALENTMATCH_PATH=
TTC_GOLDSCORE_URL=
TTC_GOLDSCORE_TOKEN=
TTC_GOLDSCORE_LOCAL_ENABLED=false

# Sentry monitoring (optional)
TTC_SENTRY_DSN=
TTC_SENTRY_ENVIRONMENT=development
TTC_SENTRY_RELEASE=ttc-daemon@0.3.0
TTC_SENTRY_TRACES_SAMPLE_RATE=0.1
TTC_SENTRY_PROFILES_SAMPLE_RATE=0.0
TTC_SENTRY_SEND_PII=false

# Source 人才库 JSON 文件（可选）
TTC_SOURCE_TALENT_ENABLED=false
TTC_SOURCE_TALENT_FILE=/path/to/source-candidates.json
