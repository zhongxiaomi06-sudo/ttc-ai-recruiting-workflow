# 复制为 .env 后填充真实值

# API 认证
TTC_API_TOKEN=change-me

# 飞书通知（lark-cli 兜底）
TTC_FEISHU_NOTIFY_ENABLED=false
TTC_FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书 Bot（talentmatch 卡片交互）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_WEBHOOK_URL=https://your-domain/feishu/webhook/event

# 阿里云
ALIBABA_CLOUD_ACCESS_KEY_ID=your-ak-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-ak-secret
ALIBABA_CLOUD_REGION=cn-hangzhou

# Source 人才库：JSON 文件
TTC_SOURCE_TALENT_ENABLED=false
TTC_SOURCE_TALENT_FILE=/path/to/source-candidates.json

# Source 人才库：MySQL
TTC_MYSQL_HOST=your-mysql-host
TTC_MYSQL_PORT=3306
TTC_MYSQL_DATABASE=recruit_bot
TTC_MYSQL_USER=ttc_reader
TTC_MYSQL_PASSWORD=your-password

# 公司人才库 API
TTC_TALENT_DB_ENABLED=false
TTC_TALENT_DB_URL=https://your-talent-db.example.com/api/search
TTC_TALENT_DB_KEY=your-api-key

# LLM
TTC_LLM_API_KEY=sk-...
TTC_LLM_BASE_URL=https://api.openai.com/v1
TTC_LLM_MODEL=gpt-4o-mini

# talentmatch 数据与向量存储
TALENTMATCH_DB_PATH=/Users/ashley/Downloads/ttc的交易系统/ttc-automation/daemon/data/talentmatch.db
CHROMA_PERSIST_DIR=/Users/ashley/Downloads/ttc的交易系统/ttc-automation/daemon/data/chroma

# 训练数据 RDS（可选，仅训练节点需要）
RDS_HOST=your-rds-host
RDS_PORT=3306
RDS_USER=your-rds-user
RDS_PASSWORD=your-rds-password
RDS_DATABASE=recruit_training
